    {
      "parameters": {
        "language": "pythonNative",
        "pythonCode": "rows = _items\n\nhistory = \"\"\n\nfor row in rows:\n    question = row[\"json\"].get(\"question\", \"\")\n    answer = row[\"json\"].get(\"answer\", \"\")\n\n    if answer.strip():   # Only include answered conversations\n        history += f\"Student: {question}\\n\"\n        history += f\"Tutor: {answer}\\n\\n\"\n\nif not history:\n    history = \"No previous conversation\"\n\nreturn [{\n    \"json\": {\n        \"history\": history\n    }\n}]"
      },
